[
  {
    "type": "Section",
    "name": "view",
    "label": "Brick Lab"
  },
  {
    "type": "Dropdown",
    "name": "view_mode",
    "label": "View",
    "description": "Inspect one configurable part or a six-part library sampler",
    "options": [
      { "value": "single", "label": "Single part" },
      { "value": "sampler", "label": "Part sampler" }
    ],
    "defaultValue": "single"
  },
  {
    "type": "Dropdown",
    "name": "part_type",
    "label": "Part",
    "description": "LEGO.scad block family",
    "options": [
      { "value": "brick", "label": "Brick" },
      { "value": "tile", "label": "Tile" },
      { "value": "slope", "label": "Slope" },
      { "value": "curve", "label": "Curve" },
      { "value": "wing", "label": "Wing" },
      { "value": "round", "label": "Round" },
      { "value": "round-tile", "label": "Round tile" },
      { "value": "baseplate", "label": "Baseplate" }
    ],
    "defaultValue": "brick",
    "visibleWhen": { "field": "view_mode", "operator": "equals", "value": "single" }
  },
  {
    "type": "Slider",
    "name": "brick_width",
    "label": "Width",
    "description": "Part width in studs",
    "range": "1,12,1",
    "defaultValue": "2",
    "visibleWhen": { "field": "view_mode", "operator": "equals", "value": "single" }
  },
  {
    "type": "Slider",
    "name": "brick_length",
    "label": "Length",
    "description": "Part length in studs",
    "range": "1,16,1",
    "defaultValue": "4",
    "visibleWhen": { "field": "view_mode", "operator": "equals", "value": "single" }
  },
  {
    "type": "Dropdown",
    "name": "height_preset",
    "label": "Height",
    "description": "Plate, standard brick, or double brick height",
    "options": [
      { "value": "plate", "label": "Plate (1/3)" },
      { "value": "brick", "label": "Brick (1x)" },
      { "value": "double", "label": "Double (2x)" }
    ],
    "defaultValue": "brick",
    "visibleWhen": { "field": "view_mode", "operator": "equals", "value": "single" }
  },
  {
    "type": "Section",
    "name": "construction",
    "label": "Construction"
  },
  {
    "type": "Dropdown",
    "name": "brand",
    "label": "System",
    "description": "Standard or DUPLO-compatible dimensions",
    "options": [
      { "value": "lego", "label": "LEGO-compatible" },
      { "value": "duplo", "label": "DUPLO-compatible" }
    ],
    "defaultValue": "lego"
  },
  {
    "type": "Dropdown",
    "name": "stud_type",
    "label": "Studs",
    "description": "Top stud construction",
    "options": [
      { "value": "solid", "label": "Solid" },
      { "value": "hollow", "label": "Hollow" },
      { "value": "open", "label": "Open" }
    ],
    "defaultValue": "solid"
  },
  {
    "type": "Checkbox",
    "name": "technic_holes",
    "label": "Technic holes",
    "description": "Add horizontal axle holes",
    "defaultValue": false,
    "visibleWhen": { "field": "view_mode", "operator": "equals", "value": "single" }
  },
  {
    "type": "Dropdown",
    "name": "technic_hole_shape",
    "label": "Hole shape",
    "description": "Round or cross-shaped horizontal holes",
    "options": [
      { "value": "cross", "label": "Cross" },
      { "value": "round", "label": "Round" }
    ],
    "defaultValue": "cross",
    "visibleWhen": { "field": "technic_holes", "operator": "truthy" }
  },
  {
    "type": "Dropdown",
    "name": "curve_type",
    "label": "Curve",
    "options": [
      { "value": "convex", "label": "Convex" },
      { "value": "concave", "label": "Concave" }
    ],
    "defaultValue": "convex",
    "visibleWhen": { "field": "part_type", "operator": "equals", "value": "curve" }
  },
  {
    "type": "Dropdown",
    "name": "wing_type",
    "label": "Wing side",
    "options": [
      { "value": "left", "label": "Left" },
      { "value": "right", "label": "Right" },
      { "value": "full", "label": "Full" }
    ],
    "defaultValue": "left",
    "visibleWhen": { "field": "part_type", "operator": "equals", "value": "wing" }
  },
  {
    "type": "Section",
    "name": "appearance",
    "label": "Appearance"
  },
  {
    "type": "Color",
    "name": "brick_color",
    "label": "Color",
    "description": "Display color for the selected part",
    "defaultValue": "#d71920",
    "visibleWhen": { "field": "view_mode", "operator": "equals", "value": "single" }
  },
  {
    "type": "Checkbox",
    "name": "show_underside",
    "label": "Show underside",
    "description": "Flip the model to inspect posts, walls, and splines",
    "defaultValue": false
  },
  {
    "type": "Dropdown",
    "name": "quality",
    "label": "Geometry quality",
    "description": "Draft is faster; print uses finer curved surfaces",
    "options": [
      { "value": "draft", "label": "Draft" },
      { "value": "print", "label": "Print" }
    ],
    "defaultValue": "draft"
  }
]
